OPENAI_API_KEY=sk-...
SERVER_PORT=3000

# Redis — spun up via docker-compose (see /docker-compose.yml)
REDIS_URL=redis://localhost:6379

# MinIO — S3-compatible object storage for audio recordings (optional)
# MinIO is OFF by default. To enable: set MINIO_ENABLED=true and run docker-compose up minio
# Console: http://localhost:9001  (minioadmin / minioadmin)
# MINIO_ENABLED=true
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=langmate-media
MINIO_USE_SSL=false
